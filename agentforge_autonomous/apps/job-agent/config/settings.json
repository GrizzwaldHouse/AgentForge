{
  "pipeline": {
    "batchSize": 5,
    "matchScoreThreshold": 40,
    "criticScoreThreshold": 65,
    "maxCriticRetries": 2,
    "logLevel": "info"
  },
  "model": {
    "proposalModel": "llama3:8b",
    "criticModel": "llama3:8b",
    "maxTokens": 2048,
    "temperature": 0.7
  },
  "paths": {
    "outputsBase": "outputs",
    "matchesRaw": "outputs/matches/raw",
    "proposals": "outputs/proposals",
    "applications": "outputs/applications",
    "jobSources": "data/job-sources.json",
    "rejectionPatterns": "data/rejection_patterns.seed.json",
    "coreMemory": "memory/core_memory.json",
    "proposalPrompt": "apps/job-agent/config/prompts/proposal.md"
  },
  "sources": {
    "phase1": ["data/job-sources.json"],
    "phase2": ["himalayas", "remoteok"]
  },
  "budget": {
    "dailyLimitUsd": 1.0,
    "maxCostPerProposal": 0.05
  },
  "retry": {
    "maxAttempts": 3,
    "backoffMs": 1000
  },
  "resume": {
    "vaultPath": "C:/Users/daley/Resumes",
    "minMatchScore": 0.65,
    "vmockPassThreshold": 75,
    "maxIterations": 3,
    "authStatePath": "agents/A5-auto-apply/vmock-auth.json",
    "screenshotDir": "agents/A5-auto-apply/jobs",
    "hfMatchModel": "sentence-transformers/all-MiniLM-L6-v2",
    "hfApiBase": "https://api-inference.huggingface.co/models",
    "vmockSelectors": {
      "fileInput": "input[type=file]",
      "jdTextarea": "textarea[placeholder*='description' i]",
      "submitButton": "button[type=submit]",
      "scoreElement": "[data-testid='score-value']",
      "feedbackItems": "[data-testid='feedback-item']"
    }
  }
}
