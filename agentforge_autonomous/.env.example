# SeniorDevBuddy / AgentForge — Environment Variables
# Copy this to .env.local and fill in your values.
# NEVER commit .env.local to source control.

# === Local LLM (Required) ===
OLLAMA_BASE_URL=http://127.0.0.1:11434

# === Cloud LLM Providers (Optional — fallback chain) ===
# Priority: Ollama → Groq → Cerebras → Together → Mistral → Claude → OpenAI
# Leave blank to skip a provider. Free-tier providers used first.
GROQ_API_KEY=
CEREBRAS_API_KEY=
TOGETHER_API_KEY=
MISTRAL_API_KEY=

# === Paid Fallback Providers (last resort) ===
CLAUDE_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# === API Security ===
# Set a shared secret to protect POST /api/agent/run from unauthorized callers.
# Any non-empty value enables the X-Agent-Token header check.
AGENT_TOKEN=

# === Budget ===
DAILY_BUDGET_USD=1.00

# === Runtime ===
NODE_ENV=development
